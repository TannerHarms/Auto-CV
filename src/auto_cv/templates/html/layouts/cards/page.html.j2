{# Cards layout — extra page #}
{% from "partials/nav.html.j2" import render_nav %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ page.title }} — {{ resume.config.name }}</title>
  <style>
    :root {
      {% for key, val in css_vars.items() %}
      {{ key }}: {{ val }};
      {% endfor %}
    }
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: var(--font-body); font-size: var(--font-size-base);
      line-height: var(--spacing-line-height); color: var(--color-text);
      background: #eee; margin: 0;
    }
    a { color: var(--color-link); }
    .resume-nav { display: flex; gap: 1rem; justify-content: center; padding: 0.75rem 0; background: var(--color-background); border-bottom: 1px solid var(--color-border); }
    .nav-link { font-size: 0.9rem; color: var(--color-link); }
    .nav-link.active { font-weight: 700; color: var(--color-primary); }
    .page-card {
      max-width: 850px; margin: 2rem auto; background: var(--color-background);
      border-radius: 6px; box-shadow: 0 2px 6px rgba(0,0,0,0.08); padding: 2rem;
    }
    .page-title { font-family: var(--font-heading); font-size: 1.5rem; color: var(--color-heading); border-bottom: 2px solid var(--color-primary); padding-bottom: 4px; margin-bottom: 1rem; }
    .page-content img { max-width: 100%; }
    @media print { body { background: #fff; } .page-card { box-shadow: none; } .resume-nav { display: none; } }
  </style>
  {% if custom_css %}
  <style>{{ custom_css | safe }}</style>
  {% endif %}
</head>
<body>
  {{ render_nav(resume, pages, has_pages, active_id=page.id) }}
  <div class="page-card">
    <h1 class="page-title">{{ page.title }}</h1>
    <div class="page-content">{{ page.raw_content | markdown | safe }}</div>
  </div>
  {% if custom_js %}<script>{{ custom_js | safe }}</script>{% endif %}
</body>
</html>
