{# Multi-page layout — each section is its own page, with section navigation #}
{% from "partials/sections.html.j2" import render_section %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ resume.config.html_meta.get('title', resume.config.name + ' — Resume') }}</title>
  {% if resume.config.html_meta.get('description') %}
  <meta name="description" content="{{ resume.config.html_meta['description'] }}">
  {% endif %}
  <style>
    :root {
      {% for key, val in css_vars.items() %}
      {{ key }}: {{ val }};
      {% endfor %}
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-body), Georgia, serif;
      font-size: var(--font-size-base);
      line-height: var(--spacing-line-height);
      color: var(--color-text);
      background: var(--color-background);
      max-width: 900px;
      margin: 0 auto;
      padding: var(--spacing-page-margin);
    }

    a { color: var(--color-link); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* --- Header --- */
    .resume-header {
      text-align: center;
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 2px solid var(--color-primary);
    }
    .resume-name {
      font-family: var(--font-heading);
      font-size: var(--font-size-name);
      color: var(--color-primary);
      font-weight: 700;
      margin-bottom: 0.25rem;
    }
    .resume-title {
      font-size: 1.1rem;
      color: var(--color-secondary);
      margin-bottom: 0.5rem;
    }
    .resume-contact {
      font-size: var(--font-size-small);
      color: var(--color-text);
    }
    .resume-contact span + span::before {
      content: " | ";
      color: var(--color-border);
    }

    /* --- Section Navigation --- */
    .section-nav {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      justify-content: center;
      margin-bottom: 2rem;
      padding: 0.75rem 0;
      border-bottom: 1px solid var(--color-border);
    }
    .section-nav-link {
      font-size: 0.9rem;
      color: var(--color-link);
      padding: 0.25rem 0.75rem;
      border-radius: 4px;
      transition: background 0.2s;
    }
    .section-nav-link:hover {
      background: var(--color-primary);
      color: #fff;
      text-decoration: none;
    }
    .section-nav-link.active {
      font-weight: 700;
      color: #fff;
      background: var(--color-primary);
    }

    /* --- Page Nav (for vault pages) --- */
    .page-nav {
      display: flex;
      gap: 1rem;
      justify-content: center;
      margin-bottom: 1rem;
      padding: 0.5rem 0;
      font-size: 0.85rem;
    }
    .page-nav a { color: var(--color-secondary); }
    .page-nav a.active { font-weight: 700; color: var(--color-primary); }

    /* --- Sections --- */
    .resume-section { margin-bottom: var(--spacing-section-gap); }
    .section-title {
      font-family: var(--font-heading);
      font-size: var(--font-size-heading);
      color: var(--color-heading);
      border-bottom: 1px solid var(--color-primary);
      padding-bottom: 4px;
      margin-bottom: 0.75rem;
    }

    /* --- Entries (same as top-header) --- */
    .entry { margin-bottom: var(--spacing-entry-gap); }
    .entry-header { margin-bottom: 0.25rem; }
    .entry-title-line {
      display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap;
    }
    .entry-title { font-size: 1rem; color: var(--color-heading); margin: 0; }
    .entry-dates { font-size: var(--font-size-small); color: var(--color-secondary); }
    .entry-subtitle-line { display: flex; justify-content: space-between; flex-wrap: wrap; }
    .entry-org { color: var(--color-accent); font-style: italic; }
    .entry-location { font-size: var(--font-size-small); color: var(--color-secondary); }
    .entry-tech { font-size: var(--font-size-small); color: var(--color-secondary); font-style: italic; }
    .entry-description { margin: 0.25rem 0; }
    .entry-highlights { margin: 0.25rem 0 0 1.5rem; padding: 0; }
    .entry-highlights li { margin-bottom: 2px; }
    .skills-grid { display: flex; flex-direction: column; gap: 0.25rem; }
    .entry-authors { font-size: 0.9rem; color: var(--color-secondary); }
    .entry-venue { font-size: 0.9rem; color: var(--color-accent); font-style: italic; }

    /* --- Print --- */
    @media print {
      body { max-width: 100%; padding: 0.5in; font-size: 10pt; }
      .section-nav, .page-nav { display: none; }
      a { color: inherit; text-decoration: none; }
    }
  </style>
  {% if custom_css %}
  <style>{{ custom_css | safe }}</style>
  {% endif %}
</head>
<body>
  <header class="resume-header">
    <h1 class="resume-name">{{ resume.config.name }}</h1>
    {% if resume.config.title %}
    <p class="resume-title">{{ resume.config.title }}</p>
    {% endif %}
    <div class="resume-contact">
      {% if resume.config.contact.email %}<span>{{ resume.config.contact.email }}</span>{% endif %}
      {% if resume.config.contact.phone %}<span>{{ resume.config.contact.phone }}</span>{% endif %}
      {% if resume.config.contact.location %}<span>{{ resume.config.contact.location }}</span>{% endif %}
      {% if resume.config.contact.linkedin %}<span><a href="https://linkedin.com/in/{{ resume.config.contact.linkedin }}">LinkedIn</a></span>{% endif %}
      {% if resume.config.contact.github %}<span><a href="https://github.com/{{ resume.config.contact.github }}">GitHub</a></span>{% endif %}
      {% if resume.config.contact.website %}<span><a href="{{ resume.config.contact.website }}">Website</a></span>{% endif %}
    </div>
  </header>

  {# Section navigation tabs #}
  <nav class="section-nav">
    {% for section in all_sections %}
    <a href="{{ section.id }}.html" class="section-nav-link {% if active_section_id == section.id %}active{% endif %}">{{ section.title }}</a>
    {% endfor %}
  </nav>

  {# Page navigation if vault pages exist #}
  {% if has_pages %}
  <nav class="page-nav">
    {% for page in pages %}
    <a href="page-{{ page.id }}.html">{{ page.title }}</a>
    {% endfor %}
  </nav>
  {% endif %}

  <main>
    {% if active_section %}
    {{ render_section(active_section, style) }}
    {% else %}
    {# Index/landing: show summary or first section #}
    {% if sections %}
    {{ render_section(sections[0], style) }}
    {% endif %}
    {% endif %}
  </main>

  <!-- Auto CV attribution — remove this block to hide -->
  <footer class="auto-cv-attribution" style="text-align:center;padding:1.5rem 0 0.75rem;margin-top:2rem;font-size:0.75rem;color:#999;border-top:1px solid #eee;">
    Resume formatted and compiled by <a href="https://github.com/TannerHarms/Auto-CV" style="color:#999;text-decoration:underline;">Auto CV</a>
  </footer>

  {% if custom_js %}
  <script>{{ custom_js | safe }}</script>
  {% endif %}
</body>
</html>
