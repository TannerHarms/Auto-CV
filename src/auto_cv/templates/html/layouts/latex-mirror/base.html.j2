{# Latex-mirror layout — CSS that closely approximates a LaTeX document #}
{% from "partials/sections.html.j2" import render_section %}
{% from "partials/nav.html.j2" import render_nav %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ resume.config.html_meta.get('title', resume.config.name + ' — Resume') }}</title>
  {% if resume.config.html_meta.get('description') %}
  <meta name="description" content="{{ resume.config.html_meta['description'] }}">
  {% endif %}
  <style>
    @import url('https://fonts.googleapis.com/css2?family=EB+Garamond:ital,wght@0,400;0,600;0,700;1,400&family=Source+Code+Pro:wght@400;600&display=swap');

    :root {
      {% for key, val in css_vars.items() %}
      {{ key }}: {{ val }};
      {% endfor %}
      --latex-font: 'EB Garamond', 'Palatino Linotype', Palatino, 'Book Antiqua', Georgia, serif;
      --latex-mono: 'Source Code Pro', 'Courier New', monospace;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--latex-font);
      font-size: 11pt;
      line-height: 1.35;
      color: #000;
      background: #f8f8f8;
    }

    .page {
      max-width: 8.5in;
      margin: 0.5in auto;
      padding: 0.75in 0.85in;
      background: #fff;
      box-shadow: 0 1px 8px rgba(0,0,0,0.12);
    }

    a { color: var(--color-link, #2C3E50); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* --- Header: centered, LaTeX-like --- */
    .resume-header {
      text-align: center;
      margin-bottom: 14pt;
    }
    .resume-name {
      font-family: var(--latex-font);
      font-size: 20pt;
      font-weight: 700;
      color: #000;
      letter-spacing: 0.5pt;
      margin-bottom: 2pt;
    }
    .resume-title {
      font-size: 11pt;
      color: #444;
      font-style: italic;
      margin-bottom: 4pt;
    }
    .resume-contact {
      font-size: 9pt;
      color: #333;
    }
    .resume-contact span + span::before {
      content: " \00a0|\00a0 ";
      color: #999;
    }

    /* --- Sections: bold heading with rule underneath (like \section in LaTeX) --- */
    .resume-section {
      margin-bottom: 12pt;
    }
    .section-title {
      font-family: var(--latex-font);
      font-size: 12pt;
      font-weight: 700;
      color: #000;
      text-transform: uppercase;
      letter-spacing: 0.5pt;
      border-bottom: 0.6pt solid #000;
      padding-bottom: 2pt;
      margin-bottom: 6pt;
    }

    /* --- Entries: replicate \cventry layout --- */
    .entry { margin-bottom: 8pt; }
    .entry-header { margin-bottom: 2pt; }
    .entry-title-line {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
    }
    .entry-title {
      font-size: 11pt;
      font-weight: 700;
      color: #000;
      margin: 0;
    }
    .entry-dates {
      font-size: 9pt;
      color: #555;
      white-space: nowrap;
    }
    .entry-subtitle-line {
      display: flex;
      justify-content: space-between;
    }
    .entry-org {
      color: #444;
      font-style: italic;
    }
    .entry-location {
      font-size: 9pt;
      color: #555;
    }
    .entry-tech {
      font-size: 9pt;
      font-style: italic;
      color: #555;
    }
    .entry-description {
      margin: 2pt 0;
      text-align: justify;
    }
    .entry-highlights {
      margin: 2pt 0 0 18pt;
      padding: 0;
    }
    .entry-highlights li {
      margin-bottom: 1pt;
      text-align: justify;
    }

    /* --- Skills --- */
    .skills-grid { display: flex; flex-direction: column; gap: 2pt; }
    .skill-category strong { font-weight: 700; }
    .skill-category strong::after { content: ':'; }
    .skill-category .skill-list { margin-left: 0.3em; }

    /* --- Publications: citation style --- */
    .pub-entry { margin-bottom: 4pt; }
    .entry-authors { font-size: 10pt; color: #333; }
    .entry-venue { font-size: 10pt; color: #444; }

    /* --- Awards --- */
    .award-entry .entry-org { font-style: italic; color: #444; }

    /* --- Certifications --- */
    .cert-entry { margin-bottom: 4pt; }

    /* --- Nav (only for multi-page) --- */
    .resume-nav {
      display: flex; gap: 1rem; justify-content: center;
      margin-bottom: 12pt; padding: 4pt 0;
      border-bottom: 0.4pt solid #ccc;
      font-size: 9pt;
    }
    .nav-link { color: #444; }
    .nav-link.active { font-weight: 700; color: #000; }

    /* --- Print --- */
    @media print {
      body { background: #fff; }
      .page { box-shadow: none; margin: 0; padding: 0.5in; font-size: 10pt; }
      .resume-nav { display: none; }
      a { color: #000; }
    }
  </style>
  {% if custom_css %}
  <style>{{ custom_css | safe }}</style>
  {% endif %}
</head>
<body>
  <div class="page">
    {{ render_nav(resume, pages, has_pages) }}

    <header class="resume-header">
      <h1 class="resume-name">{{ resume.config.name }}</h1>
      {% if resume.config.title %}
      <p class="resume-title">{{ resume.config.title }}</p>
      {% endif %}
      <div class="resume-contact">
        {% if resume.config.contact.email %}<span>{{ resume.config.contact.email }}</span>{% endif %}
        {% if resume.config.contact.phone %}<span>{{ resume.config.contact.phone }}</span>{% endif %}
        {% if resume.config.contact.location %}<span>{{ resume.config.contact.location }}</span>{% endif %}
        {% if resume.config.contact.linkedin %}<span><a href="https://linkedin.com/in/{{ resume.config.contact.linkedin }}">LinkedIn</a></span>{% endif %}
        {% if resume.config.contact.github %}<span><a href="https://github.com/{{ resume.config.contact.github }}">GitHub</a></span>{% endif %}
        {% if resume.config.contact.website %}<span><a href="{{ resume.config.contact.website }}">Website</a></span>{% endif %}
      </div>
    </header>

    <main>
      {% for section in sections %}
      {{ render_section(section, style) }}
      {% endfor %}
    </main>
  </div>

  <!-- Auto CV attribution — remove this block to hide -->
  <footer class="auto-cv-attribution" style="text-align:center;padding:1.5rem 0 0.75rem;margin-top:2rem;font-size:0.75rem;color:#999;border-top:1px solid #eee;">
    Resume formatted and compiled by <a href="https://github.com/TannerHarms/Auto-CV" style="color:#999;text-decoration:underline;">Auto CV</a>
  </footer>

  {% if custom_js %}
  <script>{{ custom_js | safe }}</script>
  {% endif %}
</body>
</html>
