{# Sidebar layout — two-column: sidebar (contact/skills/photo) + main content #}
{% from "partials/sections.html.j2" import render_section %}
{% from "partials/nav.html.j2" import render_nav %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ resume.config.html_meta.get('title', resume.config.name + ' — Resume') }}</title>
  {% if resume.config.html_meta.get('description') %}
  <meta name="description" content="{{ resume.config.html_meta['description'] }}">
  {% endif %}
  <style>
    :root {
      {% for key, val in css_vars.items() %}
      {{ key }}: {{ val }};
      {% endfor %}
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-body), Georgia, serif;
      font-size: var(--font-size-base);
      line-height: var(--spacing-line-height);
      color: var(--color-text);
      background: #f5f5f5;
      margin: 0;
    }

    a { color: var(--color-link); text-decoration: none; }
    a:hover { text-decoration: underline; }

    .resume-wrapper {
      display: flex;
      max-width: 1100px;
      margin: 2rem auto;
      background: var(--color-background);
      box-shadow: 0 2px 8px rgba(0,0,0,0.1);
      min-height: 100vh;
    }

    /* --- Sidebar --- */
    .sidebar {
      width: 280px;
      flex-shrink: 0;
      background: var(--color-primary);
      color: #fff;
      padding: 2rem 1.5rem;
    }
    .sidebar a { color: #ddd; }
    .sidebar a:hover { color: #fff; }
    .sidebar .resume-photo {
      width: 140px;
      height: 140px;
      border-radius: 50%;
      object-fit: cover;
      display: block;
      margin: 0 auto 1.5rem;
      border: 3px solid rgba(255,255,255,0.3);
    }
    .sidebar .resume-name {
      font-family: var(--font-heading);
      font-size: 1.4rem;
      text-align: center;
      margin-bottom: 0.25rem;
    }
    .sidebar .resume-title-text {
      text-align: center;
      font-size: 0.9rem;
      opacity: 0.8;
      margin-bottom: 1.5rem;
    }
    .sidebar-section { margin-bottom: 1.5rem; }
    .sidebar-section h3 {
      font-size: 0.85rem;
      text-transform: uppercase;
      letter-spacing: 1px;
      opacity: 0.7;
      margin-bottom: 0.5rem;
      border-bottom: 1px solid rgba(255,255,255,0.2);
      padding-bottom: 4px;
    }
    .sidebar-section p,
    .sidebar-section li {
      font-size: 0.9rem;
      margin-bottom: 0.25rem;
    }
    .sidebar-section ul { list-style: none; padding: 0; }

    /* --- Main --- */
    .main-content {
      flex: 1;
      padding: 2rem;
    }

    .resume-nav {
      display: flex; gap: 1rem;
      margin-bottom: 1.5rem; padding: 0.5rem 0;
      border-bottom: 1px solid var(--color-border);
    }
    .nav-link { font-size: 0.9rem; color: var(--color-link); }
    .nav-link.active { font-weight: 700; color: var(--color-primary); }

    .resume-section { margin-bottom: var(--spacing-section-gap); }
    .section-title {
      font-family: var(--font-heading);
      font-size: var(--font-size-heading);
      color: var(--color-heading);
      border-bottom: 1px solid var(--color-primary);
      padding-bottom: 4px;
      margin-bottom: 0.75rem;
    }

    .entry { margin-bottom: var(--spacing-entry-gap); }
    .entry-title-line { display: flex; justify-content: space-between; align-items: baseline; flex-wrap: wrap; }
    .entry-title { font-size: 1rem; color: var(--color-heading); margin: 0; }
    .entry-dates { font-size: var(--font-size-small); color: var(--color-secondary); }
    .entry-subtitle-line { display: flex; justify-content: space-between; flex-wrap: wrap; }
    .entry-org { color: var(--color-accent); font-style: italic; }
    .entry-location { font-size: var(--font-size-small); color: var(--color-secondary); }
    .entry-tech { font-size: var(--font-size-small); color: var(--color-secondary); font-style: italic; }
    .entry-highlights { margin: 0.25rem 0 0 1.5rem; padding: 0; }
    .entry-highlights li { margin-bottom: 2px; }
    .skills-grid { display: flex; flex-direction: column; gap: 0.25rem; }
    .skill-category strong::after { content: ':'; }
    .skill-category .skill-list { margin-left: 0.3em; }

    /* --- Responsive --- */
    @media (max-width: 768px) {
      .resume-wrapper { flex-direction: column; margin: 0; }
      .sidebar { width: 100%; }
    }

    /* --- Print --- */
    @media print {
      body { background: #fff; }
      .resume-wrapper { box-shadow: none; margin: 0; }
      .sidebar { background: var(--color-primary); -webkit-print-color-adjust: exact; print-color-adjust: exact; }
      .resume-nav { display: none; }
      a { color: inherit; }
    }
  </style>
  {% if custom_css %}
  <style>{{ custom_css | safe }}</style>
  {% endif %}
</head>
<body>
  <div class="resume-wrapper">
    <aside class="sidebar">
      {% if style.html.include_photo and resume.config.photo %}
      <img src="assets/{{ resume.config.photo }}" alt="Photo" class="resume-photo">
      {% endif %}
      <div class="resume-name">{{ resume.config.name }}</div>
      {% if resume.config.title %}
      <div class="resume-title-text">{{ resume.config.title }}</div>
      {% endif %}

      <div class="sidebar-section">
        <h3>Contact</h3>
        {% if resume.config.contact.email %}<p>{{ resume.config.contact.email }}</p>{% endif %}
        {% if resume.config.contact.phone %}<p>{{ resume.config.contact.phone }}</p>{% endif %}
        {% if resume.config.contact.location %}<p>{{ resume.config.contact.location }}</p>{% endif %}
        {% if resume.config.contact.linkedin %}<p><a href="https://linkedin.com/in/{{ resume.config.contact.linkedin }}">LinkedIn</a></p>{% endif %}
        {% if resume.config.contact.github %}<p><a href="https://github.com/{{ resume.config.contact.github }}">GitHub</a></p>{% endif %}
        {% if resume.config.contact.website %}<p><a href="{{ resume.config.contact.website }}">{{ resume.config.contact.website }}</a></p>{% endif %}
      </div>

      {# Render skills in sidebar if present #}
      {% for section in sections %}
      {% if section.section_type.value == "skills" %}
      <div class="sidebar-section">
        <h3>{{ section.title }}</h3>
        {% for cat in section.skill_categories %}
        <p><strong>{{ cat.name }}</strong></p>
        <ul>
          {% for skill in cat.skills %}
          <li>{{ skill }}</li>
          {% endfor %}
        </ul>
        {% endfor %}
      </div>
      {% endif %}
      {% endfor %}
    </aside>

    <div class="main-content">
      {{ render_nav(resume, pages, has_pages) }}

      {% for section in sections %}
      {# Skip skills — they're in the sidebar #}
      {% if section.section_type.value != "skills" %}
      {{ render_section(section, style) }}
      {% endif %}
      {% endfor %}
    </div>
  </div>

  {% if custom_js %}
  <script>{{ custom_js | safe }}</script>
  {% endif %}
</body>
</html>
