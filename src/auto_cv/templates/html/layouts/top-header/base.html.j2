{# Top-header layout — traditional single-column resume #}
{% from "partials/sections.html.j2" import render_section %}
{% from "partials/nav.html.j2" import render_nav %}
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>{{ resume.config.html_meta.get('title', resume.config.name + ' — Resume') }}</title>
  {% if resume.config.html_meta.get('description') %}
  <meta name="description" content="{{ resume.config.html_meta['description'] }}">
  {% endif %}
  {% if resume.config.html_meta.get('og_title') %}
  <meta property="og:title" content="{{ resume.config.html_meta['og_title'] }}">
  {% endif %}
  {% if resume.config.html_meta.get('og_description') %}
  <meta property="og:description" content="{{ resume.config.html_meta['og_description'] }}">
  {% endif %}
  {% if resume.config.html_meta.get('favicon') %}
  <link rel="icon" href="{{ resume.config.html_meta['favicon'] }}">
  {% endif %}
  <style>
    :root {
      {% for key, val in css_vars.items() %}
      {{ key }}: {{ val }};
      {% endfor %}
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: var(--font-body), Georgia, serif;
      font-size: var(--font-size-base);
      line-height: var(--spacing-line-height);
      color: var(--color-text);
      background: var(--color-background);
      max-width: 850px;
      margin: 0 auto;
      padding: var(--spacing-page-margin);
    }

    a { color: var(--color-link); text-decoration: none; }
    a:hover { text-decoration: underline; }

    /* --- Header --- */
    .resume-header {
      text-align: center;
      margin-bottom: 1.5rem;
      padding-bottom: 1rem;
      border-bottom: 2px solid var(--color-primary);
    }
    .resume-name {
      font-family: var(--font-heading);
      font-size: var(--font-size-name);
      color: var(--color-primary);
      font-weight: 700;
      margin-bottom: 0.25rem;
    }
    .resume-title {
      font-size: 1.1rem;
      color: var(--color-secondary);
      margin-bottom: 0.5rem;
    }
    .resume-contact {
      font-size: var(--font-size-small);
      color: var(--color-text);
    }
    .resume-contact span + span::before {
      content: " | ";
      color: var(--color-border);
    }

    /* --- Nav --- */
    .resume-nav {
      display: flex;
      gap: 1rem;
      justify-content: center;
      margin-bottom: 1.5rem;
      padding: 0.5rem 0;
      border-bottom: 1px solid var(--color-border);
    }
    .nav-link { font-size: 0.9rem; color: var(--color-link); }
    .nav-link.active { font-weight: 700; color: var(--color-primary); }

    /* --- Sections --- */
    .resume-section { margin-bottom: var(--spacing-section-gap); }
    .section-title {
      font-family: var(--font-heading);
      font-size: var(--font-size-heading);
      color: var(--color-heading);
      border-bottom: 1px solid var(--color-primary);
      padding-bottom: 4px;
      margin-bottom: 0.75rem;
    }

    /* --- Entries --- */
    .entry { margin-bottom: var(--spacing-entry-gap); }
    .entry-header { margin-bottom: 0.25rem; }
    .entry-title-line {
      display: flex;
      justify-content: space-between;
      align-items: baseline;
      flex-wrap: wrap;
    }
    .entry-title { font-size: 1rem; color: var(--color-heading); margin: 0; }
    .entry-dates { font-size: var(--font-size-small); color: var(--color-secondary); }
    .entry-subtitle-line {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
    }
    .entry-org { color: var(--color-accent); font-style: italic; }
    .entry-location { font-size: var(--font-size-small); color: var(--color-secondary); }
    .entry-tech { font-size: var(--font-size-small); color: var(--color-secondary); font-style: italic; }
    .entry-description { margin: 0.25rem 0; }
    .entry-highlights {
      margin: 0.25rem 0 0 1.5rem;
      padding: 0;
    }
    .entry-highlights li { margin-bottom: 2px; }

    /* --- Skills --- */
    .skills-grid { display: flex; flex-direction: column; gap: 0.25rem; }
    .skill-category { font-size: 0.95rem; }
    .skill-category strong::after { content: ':'; }
    .skill-category .skill-list { margin-left: 0.3em; }

    /* --- Photo --- */
    .resume-photo {
      width: 120px;
      height: 120px;
      border-radius: 50%;
      object-fit: cover;
      margin: 0 auto 1rem;
      display: block;
    }

    /* --- Print --- */
    @media print {
      body { max-width: 100%; padding: 0.5in; font-size: 10pt; }
      .resume-nav { display: none; }
      a { color: inherit; text-decoration: none; }
      .resume-header { border-bottom-color: #000; }
      .section-title { border-bottom-color: #000; }
    }
  </style>
  {% if custom_css %}
  <style>{{ custom_css | safe }}</style>
  {% endif %}
</head>
<body>
  {{ render_nav(resume, pages, has_pages) }}

  <header class="resume-header">
    {% if style.html.include_photo and resume.config.photo %}
    <img src="assets/{{ resume.config.photo }}" alt="Photo" class="resume-photo">
    {% endif %}
    <h1 class="resume-name">{{ resume.config.name }}</h1>
    {% if resume.config.title %}
    <p class="resume-title">{{ resume.config.title }}</p>
    {% endif %}
    <div class="resume-contact">
      {% if resume.config.contact.email %}<span>{{ resume.config.contact.email }}</span>{% endif %}
      {% if resume.config.contact.phone %}<span>{{ resume.config.contact.phone }}</span>{% endif %}
      {% if resume.config.contact.location %}<span>{{ resume.config.contact.location }}</span>{% endif %}
      {% if resume.config.contact.linkedin %}<span><a href="https://linkedin.com/in/{{ resume.config.contact.linkedin }}">LinkedIn</a></span>{% endif %}
      {% if resume.config.contact.github %}<span><a href="https://github.com/{{ resume.config.contact.github }}">GitHub</a></span>{% endif %}
      {% if resume.config.contact.website %}<span><a href="{{ resume.config.contact.website }}">Website</a></span>{% endif %}
    </div>
  </header>

  <main>
    {% for section in sections %}
    {{ render_section(section, style) }}
    {% endfor %}
  </main>

  {% if custom_js %}
  <script>{{ custom_js | safe }}</script>
  {% endif %}
</body>
</html>
