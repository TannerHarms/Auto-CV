<# Publications section #>
\section{<< section.title | escape_latex >>}

<% for entry in section.publication_entries %>
<% if not loop.first %>\vspace{<< style.spacing.entry_gap >>}<% endif %>
<% if entry.url %>
\cvpub{\href{<< entry.url >>}{<< entry.title | escape_latex >>}}{<< entry.venue | escape_latex if entry.venue else '' >>}{<< entry.authors | join(', ') | md_latex if entry.authors else '' >>}{<< entry.date | escape_latex if entry.date else '' >>}
<% else %>
\cvpub{<< entry.title | escape_latex >>}{<< entry.venue | escape_latex if entry.venue else '' >>}{<< entry.authors | join(', ') | md_latex if entry.authors else '' >>}{<< entry.date | escape_latex if entry.date else '' >>}
<% endif %>
<% if entry.description %>
\begin{itemize}
  \item << entry.description | md_latex >>
\end{itemize}
<% endif %>
<% endfor %>
