<# Education section #>
\section{<< section.title | escape_latex >>}

<% for entry in section.education_entries %>
<% if not loop.first %>\vspace{<< style.spacing.entry_gap >>}<% endif %>
\cvedentry{<< entry.degree | escape_latex >>}{<< entry.institution | escape_latex >>}{<< entry.dates.display | escape_latex if entry.dates else '' >>}{<< entry.location | escape_latex if entry.location else '' >>}
<% if entry.description or entry.gpa or entry.highlights or entry.coursework %>
\begin{itemize}
<% if entry.description -%>
  \item << entry.description | md_latex >>
<% endif -%>
<% if entry.gpa -%>
  \item \textbf{GPA:} << entry.gpa | escape_latex >>
<% endif -%>
<% for h in entry.highlights | default([]) %>
  \item << h | md_latex >>
<% endfor %>
<% if entry.coursework -%>
  \item \textit{Coursework:} << entry.coursework | join(', ') | escape_latex >>
<% endif -%>
\end{itemize}
<% endif %>
\vspace{1.5mm}
<% endfor %>
