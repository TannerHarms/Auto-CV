<# Skills section — uses \cvskill command for consistent spacing #>
\section{<< section.title | escape_latex >>}

<# Compute dynamic label column width: min(max label width, \skillcatlabelwidth) #>
\newlength{\sklmaxw}\setlength{\sklmaxw}{0pt}%
<% for cat in section.skill_categories %>
<% set idx = "abcdefghijklmnopqrstuvwxyz"[loop.index0 % 26] %>
\newlength{\sklcur<< idx >>}\settowidth{\sklcur<< idx >>}{\skilltypestyle{<< cat.name | escape_latex >>}}\ifdim\sklcur<< idx >>>\sklmaxw\setlength{\sklmaxw}{\sklcur<< idx >>}\fi%
<% endfor %>
\ifdim\sklmaxw>\skillcatlabelwidth\setlength{\sklmaxw}{\skillcatlabelwidth}\fi%

<% for cat in section.skill_categories %>
\cvskill{\sklmaxw}{<< cat.name | escape_latex >>}{<< cat.skills | join(', ') | md_latex >>}
<% endfor %>
