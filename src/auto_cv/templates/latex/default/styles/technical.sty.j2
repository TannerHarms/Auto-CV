<# technical.sty — Developer/engineering: monospace headings, terminal-style, compact #>
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{resume}[2026/01/01 Auto Resume — Technical]

% --- Geometry ---
\RequirePackage[<< style.latex.paper_size >>, margin=<< style.spacing.page_margin >>]{geometry}

% --- Fonts ---
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage{helvet}
\renewcommand{\familydefault}{\sfdefault}
\RequirePackage[scaled=0.85]{FiraMono}
\RequirePackage{microtype}

% --- Colors ---
\RequirePackage[dvipsnames]{xcolor}
\definecolor{primary}{HTML}{<< style.colors.primary | replace('#', '') >>}
\definecolor{secondary}{HTML}{<< style.colors.secondary | replace('#', '') >>}
\definecolor{accent}{HTML}{<< style.colors.accent | replace('#', '') >>}
\definecolor{linkcolor}{HTML}{<< style.colors.link | replace('#', '') >>}
\definecolor{headingcolor}{HTML}{<< style.colors.heading | replace('#', '') >>}
\definecolor{textcolor}{HTML}{<< style.colors.text | replace('#', '') >>}
\definecolor{codebg}{HTML}{F0F0F0}

% --- Hyperlinks ---
\RequirePackage[colorlinks=true, urlcolor=linkcolor, linkcolor=linkcolor]{hyperref}

% --- Spacing ---
\RequirePackage{enumitem}
\setlist[itemize]{nosep, left=0pt .. 1.2em, label={\color{accent}\texttt{>}}}
\RequirePackage{array}
\RequirePackage{parskip}
\RequirePackage{titlesec}

% --- Section: monospace heading with > prefix, bottom dotted rule ---
\titleformat{\section}
  {\normalsize\bfseries\ttfamily\color{headingcolor}}
  {}
  {0pt}
  {\textcolor{accent}{\texttt{>~}}\MakeUppercase}
  [\vspace{-2pt}{\color{accent}\dotfill}\vspace{2pt}]
\titlespacing{\section}{0pt}{<< style.spacing.section_gap >>}{4pt}

% ====================== STANDARD COMMAND INTERFACE ======================

\newcommand{\acvHeaderAfterNameSkip}{2pt}
\newcommand{\acvHeaderAfterPositionSkip}{2pt}
\newcommand{\acvHeaderAfterAddressSkip}{2pt}
\newcommand{\acvHeaderSocialSep}{\quad\textbar\quad}

\newcommand{\cvname}[2]{%
  {\fontsize{24}{28}\selectfont\bfseries\ttfamily\color{primary} #1 #2}%
}
\newcommand{\cvtitle}[1]{%
  {\normalsize\ttfamily\color{accent} #1}%
}
\newcommand{\cvaddress}[1]{%
  {\footnotesize\ttfamily\color{secondary} #1}%
}
\newcommand{\cvcontact}[1]{%
  {\footnotesize\ttfamily\color{secondary} #1}%
}

\newcommand{\cventry}[4]{%
  \vspace{<< style.spacing.entry_gap >>}%
  {\bfseries\color{headingcolor} #1}%
  \hfill{\footnotesize\ttfamily\color{secondary} #3}\par%
  \vspace{1pt}%
  {\color{accent}\texttt{@}~#2}%
  \ifx&#4&\else\hfill{\footnotesize\ttfamily\color{secondary} #4}\fi%
  \vspace{2pt}\par%
}

\newcommand{\cvedentry}[4]{%
  \vspace{<< style.spacing.entry_gap >>}%
  {\bfseries\color{headingcolor} #1}%
  \hfill{\footnotesize\ttfamily\color{secondary} #3}\par%
  \vspace{1pt}%
  {\color{accent}\texttt{@}~#2}%
  \ifx&#4&\else\hfill{\footnotesize\ttfamily\color{secondary} #4}\fi%
  \vspace{2pt}\par%
}

\newcommand{\cvskillcat}[2]{%
  {\bfseries\ttfamily\color{accent} #1}\hspace{6pt}{\small #2}\\[3pt]%
}

\newcommand*{\skilltypestyle}[1]{{\bfseries\ttfamily\color{accent} #1}}
\newcommand*{\skillsetstyle}[1]{{\small\color{textcolor} #1}}
\newlength{\skillcatlabelwidth}
\setlength{\skillcatlabelwidth}{<< style.spacing.skill_label_width >>}

\newcommand{\cvskill}[3]{%
  \vspace{-2.0mm}%
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \def\arraystretch{0.6}%
  \begin{tabular*}{\textwidth}{@{} >{\raggedleft\arraybackslash}p{#1} @{\hspace{2ex}} >{\raggedright\arraybackslash}p{\dimexpr\textwidth-#1-2ex\relax} @{}}%
    \skilltypestyle{#2} & \skillsetstyle{#3} \\%
  \end{tabular*}%
  \def\arraystretch{1}%
}

\newcommand{\cvlang}[3]{%
  \vspace{-2.0mm}%
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \def\arraystretch{0.6}%
  \begin{tabular*}{\textwidth}{@{} >{\raggedleft\arraybackslash}p{#1} @{\hspace{2ex}} >{\raggedright\arraybackslash}p{\dimexpr\textwidth-#1-2ex\relax} @{}}%
    \skilltypestyle{#2} & \skillsetstyle{#3} \\%
  \end{tabular*}%
  \def\arraystretch{1}%
}

\newcommand{\cvawardcompact}[2]{%
  {\bfseries\ttfamily\color{headingcolor} #1}\hfill{\small\color{secondary} #2}\par%
}

\newcommand{\cvawardexpressive}[4]{%
  \vspace{<< style.spacing.entry_gap >>}%
  {\bfseries\ttfamily\color{headingcolor} #1}\ifx&#4&\else\hfill{\small\color{secondary} #4}\fi\par%
  \ifx&#2&\else{\color{accent} #2}\fi%
  \ifx&#3&\else\hfill{\small\color{secondary} #3}\fi%
  \vspace{2pt}\par%
}

\newcommand{\cvservice}[4]{%
  \vspace{<< style.spacing.entry_gap >>}%
  {\bfseries\ttfamily\color{headingcolor} #1}\ifx&#2&\else{, \color{secondary}#2}\fi%
  \ifx&#3&\else\hfill{\small\color{secondary} #3}\fi\par%
  \ifx&#4&\else{\small\color{textcolor} #4}\fi%
  \vspace{2pt}\par%
}

\newcommand{\cvproject}[3]{%
  \vspace{<< style.spacing.entry_gap >>}%
  {\bfseries\color{headingcolor} #1}%
  \ifx&#3&\else\hfill{\footnotesize\ttfamily\color{secondary} #3}\fi\par%
  \ifx&#2&\else{\footnotesize\ttfamily\color{accent}[#2]}\fi%
  \vspace{2pt}\par%
}

\newcommand{\cvcert}[3]{%
  \vspace{<< style.spacing.entry_gap >>}%
  {\bfseries #1}\ifx&#2&\else{\hspace{4pt}\texttt{|}\hspace{4pt}\color{accent}#2}\fi%
  \ifx&#3&\else\hfill{\footnotesize\ttfamily\color{secondary} #3}\fi\\[-2pt]%
}

\newcommand{\cvpub}[4]{%
  \vspace{<< style.spacing.entry_gap >>}%
  {\bfseries #1}\ifx&#4&\else\hfill{\footnotesize\ttfamily\color{secondary} #4}\fi\par%
  \ifx&#3&\else{\footnotesize #3}\fi%
  \ifx&#2&\else{\\\footnotesize\itshape\color{accent} #2}\fi%
  \vspace{2pt}\par%
}

\newcommand{\cvaward}[4]{%
  \vspace{<< style.spacing.entry_gap >>}%
  {\bfseries #1}\ifx&#4&\else\hfill{\footnotesize\ttfamily\color{secondary} #4}\fi\par%
  \ifx&#2&\else{\color{accent}#2}\fi%
  \ifx&#3&\else\hfill{\footnotesize\color{secondary} #3}\fi%
  \vspace{2pt}\par%
}

\newcommand{\cvsummary}[1]{%
  {\small #1}%
}

