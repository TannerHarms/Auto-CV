<# classic.sty — Traditional serif style with horizontal rules #>
\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{resume}[2026/01/01 Auto Resume — Classic]

% --- Geometry ---
\RequirePackage[<< style.latex.paper_size >>, margin=<< style.spacing.page_margin >>]{geometry}

% --- Fonts ---
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}
\RequirePackage{mathpazo}  % Palatino
\RequirePackage{microtype}

% --- Colors ---
\RequirePackage[dvipsnames]{xcolor}
\definecolor{primary}{HTML}{<< style.colors.primary | replace('#', '') >>}
\definecolor{secondary}{HTML}{<< style.colors.secondary | replace('#', '') >>}
\definecolor{accent}{HTML}{<< style.colors.accent | replace('#', '') >>}
\definecolor{linkcolor}{HTML}{<< style.colors.link | replace('#', '') >>}
\definecolor{headingcolor}{HTML}{<< style.colors.heading | replace('#', '') >>}
\definecolor{textcolor}{HTML}{<< style.colors.text | replace('#', '') >>}

% --- Hyperlinks ---
\RequirePackage[colorlinks=true, urlcolor=linkcolor, linkcolor=linkcolor]{hyperref}

% --- Spacing ---
\RequirePackage{enumitem}
\setlist[itemize]{nosep, left=0pt .. 1.5em, label=\textbullet}
\RequirePackage{array}
\RequirePackage{parskip}
\RequirePackage{titlesec}

% --- Section: bold heading + full-width rule underneath ---
\titleformat{\section}
  {\Large\bfseries\color{headingcolor}}
  {}
  {0pt}
  {}
  [\vspace{-6pt}\textcolor{primary}{\rule{\linewidth}{0.6pt}}]
\titlespacing{\section}{0pt}{<< style.spacing.section_gap >>}{6pt}

% ====================== STANDARD COMMAND INTERFACE ======================

% --- Header commands ---
\newcommand{\acvHeaderAfterNameSkip}{2pt}
\newcommand{\acvHeaderAfterPositionSkip}{2pt}
\newcommand{\acvHeaderAfterAddressSkip}{2pt}
\newcommand{\acvHeaderSocialSep}{\quad\textbar\quad}

\newcommand{\cvname}[2]{%
  {\fontsize{24}{28}\selectfont\bfseries\color{primary} #1 #2}%
  \vspace{2pt}%
}
\newcommand{\cvtitle}[1]{%
  {\large\color{secondary}\textit{#1}}%
  \vspace{4pt}%
}
\newcommand{\cvaddress}[1]{%
  {\small\color{secondary} #1}%
}
\newcommand{\cvcontact}[1]{%
  {\small\color{textcolor} #1}%
  \vspace{4pt}%
}

% --- Experience / general entry ---
\newcommand{\cventry}[4]{%
  \vspace{<< style.spacing.entry_gap >>}%
  {\bfseries\color{headingcolor} #1}%
  \hfill{\small\color{secondary} #3}\\%
  {\itshape\color{accent} #2}%
  \ifx&#4&\else\hfill{\small\color{secondary} #4}\fi%
  \vspace{2pt}%
}

% --- Education entry ---
\newcommand{\cvedentry}[4]{%
  \vspace{<< style.spacing.entry_gap >>}%
  {\bfseries\color{headingcolor} #1}%
  \hfill{\small\color{secondary} #3}\\%
  {\itshape\color{accent} #2}%
  \ifx&#4&\else\hfill{\small\color{secondary} #4}\fi%
  \vspace{2pt}%
}

% --- Skills ---
\newcommand{\cvskillcat}[2]{%
  {\bfseries #1:} #2\\[2pt]%
}

\newcommand*{\skilltypestyle}[1]{{\bfseries\color{headingcolor} #1}}
\newcommand*{\skillsetstyle}[1]{{\color{textcolor} #1}}
\newlength{\skillcatlabelwidth}
\setlength{\skillcatlabelwidth}{<< style.spacing.skill_label_width >>}

\newcommand{\cvskill}[3]{%
  \vspace{-2.0mm}%
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \def\arraystretch{0.6}%
  \begin{tabular*}{\textwidth}{@{} >{\raggedleft\arraybackslash}p{#1} @{\hspace{2ex}} >{\raggedright\arraybackslash}p{\dimexpr\textwidth-#1-2ex\relax} @{}}%
    \skilltypestyle{#2} & \skillsetstyle{#3} \\%
  \end{tabular*}%
  \def\arraystretch{1}%
}

\newcommand{\cvlang}[3]{%
  \vspace{-2.0mm}%
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \def\arraystretch{0.6}%
  \begin{tabular*}{\textwidth}{@{} >{\raggedleft\arraybackslash}p{#1} @{\hspace{2ex}} >{\raggedright\arraybackslash}p{\dimexpr\textwidth-#1-2ex\relax} @{}}%
    \skilltypestyle{#2} & \skillsetstyle{#3} \\%
  \end{tabular*}%
  \def\arraystretch{1}%
}

\newcommand{\cvawardcompact}[2]{%
  {\bfseries\color{headingcolor} #1}\hfill{\small\color{secondary} #2}\par%
}

\newcommand{\cvawardexpressive}[4]{%
  \vspace{<< style.spacing.entry_gap >>}%
  {\bfseries\color{headingcolor} #1}\ifx&#4&\else\hfill{\small\color{secondary} #4}\fi\par%
  \ifx&#2&\else{\itshape\color{accent} #2}\fi%
  \ifx&#3&\else\hfill{\small\color{secondary} #3}\fi%
  \vspace{2pt}\par%
}

\newcommand{\cvservice}[4]{%
  \vspace{<< style.spacing.entry_gap >>}%
  {\bfseries\color{headingcolor} #1}%
  \hfill{\small\color{accent} #4}\\%
  {\itshape\color{secondary} #2}%
  \hfill{\small\color{secondary} #3}%
  \vspace{2pt}%
}

% --- Projects ---
\newcommand{\cvproject}[3]{%
  \vspace{<< style.spacing.entry_gap >>}%
  {\bfseries\color{headingcolor} #1}%
  \ifx&#3&\else\hfill{\small\color{secondary} #3}\fi\\%
  \ifx&#2&\else{\small\itshape\color{secondary} #2}\fi%
  \vspace{2pt}%
}

% --- Certifications ---
\newcommand{\cvcert}[3]{%
  \vspace{<< style.spacing.entry_gap >>}%
  {\bfseries #1}\ifx&#2&\else{ --- \textit{#2}}\fi%
  \ifx&#3&\else\hfill{\small\color{secondary} #3}\fi\\[-2pt]%
}

% --- Publications ---
\newcommand{\cvpub}[4]{%
  \vspace{<< style.spacing.entry_gap >>}%
  {\bfseries #1}\ifx&#4&\else\hfill{\small\color{secondary} #4}\fi\\%
  \ifx&#3&\else{\small #3}\fi%
  \ifx&#2&\else{\\\small\itshape #2}\fi%
  \vspace{2pt}%
}

% --- Awards ---
\newcommand{\cvaward}[4]{%
  \vspace{<< style.spacing.entry_gap >>}%
  {\bfseries #1}\ifx&#4&\else\hfill{\small\color{secondary} #4}\fi\\%
  \ifx&#2&\else{\itshape\color{accent} #2}\fi%
  \ifx&#3&\else\hfill{\small\color{secondary} #3}\fi%
  \vspace{2pt}%
}

% --- Summary ---
\newcommand{\cvsummary}[1]{%
  \textit{#1}%
}

% --- \cvref{name}{relationship}{title-and-org}{email} ---
\newcommand{\cvref}[4]{%
  \textbf{#1}\ifblank{#2}{}{ \hfill \textit{#2}}\\%
  \ifblank{#3}{}{{#3}\ifblank{#4}{}{~|~{#4}}\\}%
}

<% for pkg in style.latex.extra_packages %>
\RequirePackage{<< pkg >>}
<% endfor %>
<< style.latex.extra_preamble >>

\color{textcolor}
