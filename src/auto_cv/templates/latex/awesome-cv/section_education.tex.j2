<# Education section — awesome-cv format #>
\cvsection{<< section.title | escape_latex >>}

\begin{cventries}

<% for entry in section.education_entries %>
\cventry
{<< entry.degree | escape_latex >>}
{<< entry.institution | escape_latex >>}
{<< (entry.location or '') | escape_latex >>}
{<< entry.dates.display | escape_latex if entry.dates else '' >>}
{<% if entry.highlights or entry.gpa %>
\begin{cvitems}
<% if entry.gpa %>
\item {\textbf{GPA:} << entry.gpa | escape_latex >>}
<% endif %>
<% for h in entry.highlights %>
\item {<< h | md_latex >>}
<% endfor %>
<% if entry.coursework %>
\item {\textbf{Coursework:} << entry.coursework | join(', ') | escape_latex >>}
<% endif %>
\end{cvitems}
<% endif %>}

<% endfor %>
\end{cventries}
