<# Certifications section — awesome-cv format #>
\cvsection{<< section.title | escape_latex >>}

\begin{cvcerts}

<% for entry in section.certification_entries %>
\cvcertitem
{<< entry.name | escape_latex >>}
{<< (entry.issuer or '') | escape_latex >>}
{<< entry.date | escape_latex if entry.date else '' >>}
<% endfor %>

\end{cvcerts}
