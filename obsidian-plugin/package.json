{
  "name": "auto-cv-obsidian",
  "version": "1.0.0",
  "description": "Build beautiful CVs and resumes from your Obsidian vault",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit && node esbuild.config.mjs production",
    "watch": "node esbuild.config.mjs",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "test": "vitest run --environment jsdom"
  },
  "keywords": [
    "obsidian",
    "plugin",
    "resume",
    "cv",
    "markdown"
  ],
  "author": "Tanner Harms",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.17.0",
    "@typescript-eslint/eslint-plugin": "^5.50.0",
    "@typescript-eslint/parser": "^5.50.0",
    "builtin-modules": "^3.3.0",
    "esbuild": "^0.17.0",
    "jsdom": "^26.0.0",
    "obsidian": "latest",
    "prettier": "^3.0.0",
    "tslib": "^2.4.0",
    "typescript": "^4.7.0",
    "vitest": "^3.1.1"
  },
  "dependencies": {}
}
