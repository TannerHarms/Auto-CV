\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{resume}[2026/01/01 Auto Resume — Awesome-CV Style]

% ==========================================================================
%  Packages (mirrors awesome-cv.cls §3rd party packages)
% ==========================================================================
\RequirePackage[letterpaper, left=2.0cm, top=1.5cm, right=2.0cm, bottom=2.0cm, footskip=.5cm]{geometry}
\RequirePackage{array}
\RequirePackage{enumitem}
\RequirePackage{ragged2e}
\RequirePackage{fancyhdr}
\RequirePackage[dvipsnames]{xcolor}
\RequirePackage{xifthen}
\RequirePackage{etoolbox}
\RequirePackage{setspace}
\RequirePackage{parskip}
\RequirePackage[hidelinks,unicode]{hyperref}
\RequirePackage[T1]{fontenc}
\RequirePackage[utf8]{inputenc}

% --- XeLaTeX: use fontspec with the original Awesome-CV fonts ---
\RequirePackage[quiet]{fontspec}
\RequirePackage{unicode-math}
% No font_dir configured — use system defaults
\defaultfontfeatures{Ligatures=TeX}
\setmainfont{Latin Modern Sans}
\newcommand*{\headerfont}{\sffamily}
\newcommand*{\headerfontlight}{\sffamily}
\newcommand*{\bodyfont}{\sffamily}
\newcommand*{\bodyfontlight}{\sffamily}
\newcommand*{\footerfont}{\sffamily}
\RequirePackage{microtype}

% ==========================================================================
%  Colors — exact awesome-cv.cls values
% ==========================================================================
\definecolor{white}{HTML}{FFFFFF}
\definecolor{black}{HTML}{000000}
\definecolor{darkgray}{HTML}{333333}
\definecolor{gray}{HTML}{5D5D5D}
\definecolor{lightgray}{HTML}{999999}
% Awesome accent colors
\definecolor{awesome-emerald}{HTML}{00A388}
\definecolor{awesome-skyblue}{HTML}{0395DE}
\definecolor{awesome-red}{HTML}{DC3522}
\definecolor{awesome-pink}{HTML}{EF4089}
\definecolor{awesome-orange}{HTML}{CC5500}
\definecolor{awesome-nephritis}{HTML}{27AE60}
\definecolor{awesome-concrete}{HTML}{95A5A6}
\definecolor{awesome-darknight}{HTML}{131A28}
% Active awesome color (set from style config)
\definecolor{awesome}{HTML}{153243}
% Text colors — match awesome-cv.cls exactly
\definecolor{darktext}{HTML}{414141}
\colorlet{text}{darkgray}
\colorlet{graytext}{gray}
\colorlet{lighttext}{lightgray}
% Link color
\definecolor{linkcolor}{HTML}{0395DE}
\hypersetup{colorlinks=true, urlcolor=linkcolor, linkcolor=linkcolor}

% ==========================================================================
%  Column types — exact awesome-cv.cls definitions
% ==========================================================================
\newcolumntype{L}[1]{>{\raggedright\let\newline\\\arraybackslash\hspace{0pt}}m{#1}}
\newcolumntype{C}[1]{>{\centering\let\newline\\\arraybackslash\hspace{0pt}}m{#1}}
\newcolumntype{R}[1]{>{\raggedleft\let\newline\\\arraybackslash\hspace{0pt}}m{#1}}

% ==========================================================================
%  Utility — \vhrulefill (the line that fills remainder of section heading)
% ==========================================================================
\def\vhrulefill#1{\leavevmode\leaders\hrule\@height#1\hfill \kern\z@}

% ==========================================================================
%  Spacing constants — from awesome-cv.cls, configurable via _style.yml
% ==========================================================================
\newcommand{\acvSectionTopSkip}{10pt}
\newcommand{\acvSectionContentTopSkip}{1.5mm}
\newcommand{\acvHeaderAfterNameSkip}{.4mm}
\newcommand{\acvHeaderAfterPositionSkip}{.4mm}
\newcommand{\acvHeaderAfterAddressSkip}{-.5mm}
\newcommand{\acvHeaderAfterSocialSkip}{6mm}
\newcommand{\acvHeaderAfterQuoteSkip}{5mm}
\newcommand{\acvHeaderSocialSep}{\quad\textbar\quad}

% ==========================================================================
%  Page style — fancy footer, no header rule
% ==========================================================================
\fancyhfoffset{0em}
\renewcommand{\headrulewidth}{0pt}
\fancyhf{}
\pagestyle{fancy}

% ==========================================================================
%  Style commands — exact font sizes from awesome-cv.cls
% ==========================================================================
% Header styles
\newcommand*{\headerfirstnamestyle}[1]{{\fontsize{32pt}{1em}\headerfontlight\color{text} #1}}
\newcommand*{\headerlastnamestyle}[1]{{\fontsize{32pt}{1em}\headerfont\bfseries\color{text} #1}}
\newcommand*{\headerpositionstyle}[1]{{\fontsize{7.6pt}{1em}\bodyfont\scshape\addfontfeatures{LetterSpace=7}\color{awesome} #1}}
\newcommand*{\headeraddressstyle}[1]{{\fontsize{8pt}{1em}\headerfont\itshape\color{lighttext} #1}}
\newcommand*{\headersocialstyle}[1]{{\fontsize{6.8pt}{1em}\headerfont\color{text} #1}}
\newcommand*{\headerquotestyle}[1]{{\fontsize{9pt}{1em}\bodyfont\itshape\color{darktext} #1}}
\newcommand*{\footerstyle}[1]{{\fontsize{8pt}{1em}\footerfont\scshape\color{lighttext} #1}}

% Section style
\newcommand*{\sectionstyle}[1]{{\fontsize{16pt}{1em}\bodyfont\bfseries\color{awesome} #1}}

% Entry styles
\newcommand*{\entrytitlestyle}[1]{{\fontsize{10pt}{1em}\bodyfont\bfseries\color{darktext} #1}}
\newcommand*{\entrypositionstyle}[1]{{\fontsize{8pt}{1em}\bodyfont\scshape\color{graytext} #1}}
\newcommand*{\entrydatestyle}[1]{{\fontsize{8pt}{1em}\bodyfontlight\slshape\color{graytext} #1}}
\newcommand*{\entrylocationstyle}[1]{{\fontsize{9pt}{1em}\bodyfontlight\slshape\color{awesome} #1}}
\newcommand*{\descriptionstyle}[1]{{\fontsize{8.5pt}{1em}\bodyfontlight\upshape\color{text} #1}}

% Honor styles
\newcommand*{\honortitlestyle}[1]{{\fontsize{9pt}{1em}\bodyfont\color{graytext} #1}}
\newcommand*{\honorpositionstyle}[1]{{\fontsize{9pt}{1em}\bodyfont\bfseries\color{darktext} #1}}
\newcommand*{\honordatestyle}[1]{{\fontsize{9pt}{1em}\bodyfontlight\slshape\color{awesome} #1}}
\newcommand*{\honorlocationstyle}[1]{{\fontsize{9pt}{1em}\bodyfontlight\slshape\color{awesome} #1}}

% Skill styles
\newcommand*{\skilltypestyle}[1]{{\fontsize{10pt}{1em}\bodyfont\bfseries\color{darktext} #1}}
\newcommand*{\skillsetstyle}[1]{{\fontsize{9pt}{1em}\bodyfont\color{text} #1}}

% Paragraph style
\newcommand*{\paragraphstyle}{{\fontsize{9pt}{1em}\bodyfontlight\upshape\color{text}}}

% ==========================================================================
%  \section — awesome-cv style: colored title + gray rule filling the line
% ==========================================================================
% We override \section to match awesome-cv's \cvsection exactly:
%   \sectionstyle{title} \color{gray}\vhrulefill{1pt}
\makeatletter
\renewcommand{\section}[1]{%
  \par\addvspace{\acvSectionTopSkip}%
  \phantomsection%
  \sectionstyle{#1}%
  \color{gray}\vhrulefill{1pt}%
  \par\nobreak\addvspace{\acvSectionContentTopSkip}%
}
\makeatother

% ==========================================================================
%  cvitems environment — matches awesome-cv.cls exactly
% ==========================================================================
\newenvironment{cvitems}{%
  \vspace{-1.2mm}%
  \begin{justify}%
  \begin{itemize}[leftmargin=2ex, labelsep=0.5ex, nosep, noitemsep]%
    \setlength{\parskip}{0pt}%
    \renewcommand{\labelitemi}{\textendash}%
}{%
  \end{itemize}%
  \end{justify}%
  \vspace{1.2mm}%
}

% Also make plain \begin{itemize} match the cvitems look when used in templates
% topsep tightens the gap between the \cventry header and the bullets;
% after= adds space following the list before the next entry.
\setlist[itemize]{leftmargin=2ex, labelsep=0.5ex, nosep, noitemsep, topsep=-1.2mm, partopsep=0pt, label=\textendash, after=\vspace{1.2mm}}

% ==========================================================================
%  STANDARD COMMAND INTERFACE
%  Maps the default framework's commands to awesome-cv visual layout
% ==========================================================================

% --- Header commands ---
\newcommand{\cvname}[2]{%
  \headerfirstnamestyle{#1} \headerlastnamestyle{#2}%
}
\newcommand{\cvtitle}[1]{%
  \headerpositionstyle{#1}%
}
\newcommand{\cvaddress}[1]{%
  \headeraddressstyle{#1}%
}
\newcommand{\cvcontact}[1]{%
  \headersocialstyle{#1}%
}

% --- \cventry{title}{org}{dates}{location} ---
% Maps to awesome-cv layout:
%   Row 1: entrytitlestyle{title}  |  entrylocationstyle{location}
%   Row 2: entrypositionstyle{org} |  entrydatestyle{dates}
\newcommand{\cventry}[4]{%
  \vspace{-2.0mm}%
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \begin{tabular*}{\textwidth}{@{\extracolsep{\fill}} L{\textwidth - 4.5cm} R{4.5cm}}%
    \entrytitlestyle{#1} & \entrylocationstyle{#4} \\%
    \entrypositionstyle{#2} & \entrydatestyle{#3} \\%
  \end{tabular*}%
}

% --- \cvedentry{degree}{institution}{dates}{location} ---
\newcommand{\cvedentry}[4]{%
  \vspace{-2.0mm}%
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \begin{tabular*}{\textwidth}{@{\extracolsep{\fill}} L{\textwidth - 4.5cm} R{4.5cm}}%
    \entrytitlestyle{#1} & \entrylocationstyle{#4} \\%
    \entrypositionstyle{#2} & \entrydatestyle{#3} \\%
  \end{tabular*}%
}

% --- \cvskillcat{type}{skillset} ---
% Matches awesome-cv \cvskill layout — fixed label column prevents overflow
\newlength{\skillcatlabelwidth}
\setlength{\skillcatlabelwidth}{4.5cm}
\newcommand{\cvskillcat}[2]{%
  \setlength\tabcolsep{1ex}%
  \setlength{\extrarowheight}{0pt}%
  \begin{tabular*}{\textwidth}{@{\extracolsep{\fill}} R{\skillcatlabelwidth} p{\dimexpr\textwidth-\skillcatlabelwidth-4ex\relax}}%
    \skilltypestyle{#1} & \skillsetstyle{#2} \\%
  \end{tabular*}%
}

% --- \cvproject{name}{technologies}{dates} ---
\newcommand{\cvproject}[3]{%
  \vspace{-2.0mm}%
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \begin{tabular*}{\textwidth}{@{\extracolsep{\fill}} L{\textwidth - 4.5cm} R{4.5cm}}%
    \entrytitlestyle{#1} & \entrydatestyle{#3} \\%
    \ifblank{#2}{}{\entrypositionstyle{#2} & \\}%
  \end{tabular*}%
}

% --- \cvcert{name}{issuer}{date} ---
% Name bold on left, issuer inline unbolded, date accented on right
\newcommand{\cvcert}[3]{%
  \vspace{-2.0mm}%
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \begin{tabular*}{\textwidth}{@{\extracolsep{\fill}} L{\textwidth - 4.5cm} R{4.5cm}}%
    \entrytitlestyle{#1}\ifblank{#2}{}{~--~{#2}} & \entrylocationstyle{#3} \\%
  \end{tabular*}%
}

% --- \cvpub{title}{venue}{authors}{date} ---
% Uses cventryshort layout
\newcommand{\cvpub}[4]{%
  \vspace{-2.0mm}%
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \begin{tabular*}{\textwidth}{@{\extracolsep{\fill}} L{\textwidth - 4.5cm} R{4.5cm}}%
    \entrytitlestyle{#1} & \entrylocationstyle{#4} \\%
    \entrypositionstyle{#3} & \entrydatestyle{#2} \\%
  \end{tabular*}%
  \vspace{1.5mm}%
}

% --- \cvaward{title}{issuer}{date}{description} ---
% Title and issuer on left, date accented on right, description below
\newcommand{\cvaward}[4]{%
  \vspace{-2.0mm}%
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \begin{tabular*}{\textwidth}{@{\extracolsep{\fill}} L{\textwidth - 4.5cm} R{4.5cm}}%
    \honorpositionstyle{#1}\ifblank{#2}{}{, \honortitlestyle{#2}} & \entrylocationstyle{#3} \\%
  \end{tabular*}%
  \ifblank{#4}{}{\vspace{-1mm}\descriptionstyle{#4}\par\vspace{1mm}}%
}

% --- \cvawardcompact{title}{date} ---
% Compact 2-column layout (like societies / professional affiliations)
\newcommand{\cvawardcompact}[2]{%
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \begin{tabular*}{\textwidth}{@{\extracolsep{\fill}} L{\textwidth - 4.5cm} R{4.5cm}}%
    \entrytitlestyle{#1} & \entrydatestyle{#2} \\%
  \end{tabular*}%
}

% --- \cvawardexpressive{title}{issuer}{dates}{location} ---
% Full cventry-style layout with 2 rows (like experience entries)
\newcommand{\cvawardexpressive}[4]{%
  \vspace{-2.0mm}%
  \setlength\tabcolsep{0pt}%
  \setlength{\extrarowheight}{0pt}%
  \begin{tabular*}{\textwidth}{@{\extracolsep{\fill}} L{\textwidth - 4.5cm} R{4.5cm}}%
    \entrytitlestyle{#1} & \entrylocationstyle{#4} \\%
    \entrypositionstyle{#2} & \entrydatestyle{#3} \\%
  \end{tabular*}%
}

% --- \cvsummary{text} ---
% Matches awesome-cv \cvparagraph
\newcommand{\cvsummary}[1]{%
  \vspace{-3mm}%
  \paragraphstyle%
  #1%
  \par\vspace{2mm}%
}

% ==========================================================================
%  Footer setup — user-configurable via main.tex.j2
% ==========================================================================
% Default 3-zone footer matching awesome-cv's \makecvfooter
\fancyfoot[L]{\footerstyle{\today}}
\fancyfoot[C]{\footerstyle{Curriculum Vitae}}
\fancyfoot[R]{\footerstyle{\thepage}}



% Override \pagestyle{empty} from main.tex so the footer appears
\AtBeginDocument{\pagestyle{fancy}}

